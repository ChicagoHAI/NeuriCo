# NeuriCo .gitignore
ideas/*
!ideas/examples/
!ideas/schema.yaml
temp/
paper_examples/*
!paper_examples/README.md

# Environment variables
.env
.env.local

# Local config overrides (use .example templates)
config/workspace.yaml

# Docker image version cache (generated by ./neurico build)
.docker-image-version
mechinterp_playground/
.claude

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Research outputs (keep in workspace and GitHub repos)
runs/
workspace/
workspaces/
notebooks/
logs/

# Temporary files and logs (may contain sensitive data)
*.log
*.tmp
.cache/
**/logs/*.jsonl
**/logs/session_instructions.txt
**/logs/research_prompt.txt
**/logs/resource_finder_prompt.txt

# OS
Thumbs.db

# Paper-finder build artifacts
services/paper-finder/.venv/
services/paper-finder/**/__pycache__/

# axle_check.py runtime scratch (normalized snippet sent to AXLE)
.axle_last_check.lean

# Reserved self-built local Lean toolchain (kept on local disk only, not tracked).
# Superseded by the AXLE-backed mathematics_lean domain + axiom-lean-prover skill.
templates/domains/mathematics_lean_local/
templates/skills/lean-prover/
